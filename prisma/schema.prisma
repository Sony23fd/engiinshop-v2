generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  password  String?
  name      String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  confirmedOrders Order[] @relation("ConfirmedOrders")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  deliveryFee Decimal? @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batches     Batch[]
}

model Product {
  id            String   @id @default(cuid())
  productNumber Int      @unique @default(autoincrement())
  name          String
  description   String?
  imageUrl      String?
  videoUrl      String?
  price         Decimal
  sourceLink    String?
  isActive      Boolean  @default(true)
  weight        Decimal? @default(0.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  options       Json?
  batches       Batch[]

  @@index([isActive])
  @@index([name])
}

model Batch {
  id                 String      @id @default(cuid())
  batchNumber        Int         @unique @default(autoincrement())
  productId          String
  categoryId         String
  description        String?
  targetQuantity     Int         @default(0)
  remainingQuantity  Int         @default(0)
  cargoFeeStatus     String?
  price              Decimal?
  status             BatchStatus @default(OPEN)
  isAvailableForSale Boolean     @default(false)
  deliveryFee        Decimal?    @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  isPreOrder         Boolean     @default(false)
  closingDate        DateTime?
  category           Category    @relation(fields: [categoryId], references: [id])
  product            Product     @relation(fields: [productId], references: [id])
  orders             Order[]

  @@index([status])
  @@index([isAvailableForSale])
  @@index([categoryId])
  @@index([productId])
}

model OrderStatusType {
  id            String   @id @default(cuid())
  name          String
  color         String?  @default("slate")
  isFinal       Boolean  @default(false)
  isDefault     Boolean  @default(false)
  isDeliverable Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Order {
  id                    String           @id @default(cuid())
  orderNumber           Int              @unique @default(autoincrement())
  batchId               String
  customerName          String
  customerPhone         String
  accountNumber         String?
  quantity              Int              @default(1)
  arrivalDate           DateTime?
  deliveryDate          DateTime?
  deliveryAddress       String?
  deliveryRequestedAt   DateTime?
  statusId              String?
  cargoFee              Decimal?         @default(0)
  wantsDelivery         Boolean          @default(false)
  deliveryFeePaid       Boolean          @default(false)
  deliveryQpayInvoiceId String?
  paymentProofUrl       String?
  paymentStatus         String           @default("PENDING")
  totalAmount           Decimal?         @default(0)
  transactionRef        String?
  qpayInvoiceId         String?
  qpayQrText            String?
  qpayUrls              Json?
  ebarimtId             String?
  ebarimtQr             String?
  ebarimtLottery        String?
  ebarimtAmount         String?
  creationSource        String?          @default("WEB")
  createdByAdmin        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  isRefunded            Boolean          @default(false)
  selectedOptions       Json?
  confirmedById         String?
  confirmationMethod    String?          @default("MANUAL")
  confirmedAt           DateTime?
  confirmedBy           User?            @relation("ConfirmedOrders", fields: [confirmedById], references: [id])
  batch                 Batch            @relation(fields: [batchId], references: [id])
  status                OrderStatusType? @relation(fields: [statusId], references: [id])

  @@index([paymentStatus])
  @@index([updatedAt])
  @@index([customerPhone])
  @@index([transactionRef])
}

model ShopSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  userRole  String
  action    String
  target    String?
  targetUrl String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model VisitorLog {
  id        String   @id @default(cuid())
  ipHash    String?
  path      String
  userAgent String?
  referrer  String?
  viewTime  Int?     @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

enum Role {
  CUSTOMER
  ADMIN
  CARGO_ADMIN
  DATAADMIN
  SHOPPER
}

enum BatchStatus {
  OPEN
  CLOSED
  SHIPPED
  ARRIVED
}
